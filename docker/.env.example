# =============================================================================
# Machine-specific configuration
# Copy to .env and edit for your machine:  cp .env.example .env
# =============================================================================

# --- CUDA version (base image tag) -------------------------------------------
CUDA_VERSION=12.8.0

# --- Host user (match your host account's UID/GID) --------------------------
# Run `id` on host to check.  HOST_USER is auto-detected from $USER.
HOST_UID=1000
HOST_GID=1000

# --- Display / GUI forwarding ------------------------------------------------
DISPLAY=:1
