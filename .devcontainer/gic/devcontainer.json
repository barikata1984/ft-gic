{
  "name": "ft-gaussian-dlo — GIC (CUDA 12.1)",

  "dockerComposeFile": ["../../docker/docker-compose.yaml"],
  "service": "gic",
  "runServices": ["gic"],
  "workspaceFolder": "/workspace",

  "remoteUser": "${localEnv:USER:developer}",

  "customizations": {
    "vscode": {
      "settings": {
        // Shell
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "/bin/zsh" }
        },

        // Python — system Python 3.10 in the CUDA base image
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.analysis.extraPaths": [
          "/workspace/gic",
          "/workspace/gic/utils",
          "/workspace/gic/scene",
          "/workspace/gic/simulator",
          "/workspace/gic/gaussian_renderer"
        ],
        // GIC upstream code is not type-annotated; off avoids noise
        "python.analysis.typeCheckingMode": "off",

        // Don't auto-format upstream GIC code on save
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": false
        },

        // Files
        "files.watcherExclude": {
          "**/.git/**": true,
          "**/__pycache__/**": true,
          "**/output/**": true,
          "**/data/**": true,
          "**/wandb/**": true
        },
        "files.exclude": {
          "**/__pycache__": true
        }
      },

      "extensions": [
        // --- AI assistant ---
        "anthropic.claude-code",

        // --- Python core ---
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",

        // --- Jupyter ---
        "ms-toolsai.jupyter",

        // --- Docker & containers ---
        "ms-azuretools.vscode-docker",

        // --- Git ---
        "eamodio.gitlens",
        "mhutchie.git-graph",

        // --- Debugging ---
        "ms-python.debugpy",

        // --- File formats ---
        "redhat.vscode-yaml",

        // --- Productivity ---
        "usernamehw.errorlens",
        "gruntfuggly.todo-tree"
      ]
    }
  },

  "postCreateCommand": "echo '=== GIC container ready ===' && python3 --version && nvcc --version | tail -1",

  "shutdownAction": "none"
}
